# Copy to .env and fill in real secrets. Never commit .env.

# Database
POSTGRES_USER=ged
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=ged

# MinIO (object storage)
MINIO_ROOT_USER=ged-minio
MINIO_ROOT_PASSWORD=change-me-strong-minio-password
GED_MINIO_BUCKET=documents

# API
GED_JWT_SECRET=change-me-with-a-long-random-secret-at-least-32-chars

# HTTPS (GAP-002): set to your real domain in production; localhost for local TLS.
CADDY_DOMAIN=localhost
